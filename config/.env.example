T212_API_KEY=your_key
T212_API_SECRET=your_secret
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=AI...
FINNHUB_API_KEY=your_finnhub_key
ALPHA_VANTAGE_API_KEY=your_av_key
SLACK_WEBHOOK_URL= your_slack_webhook_url
ALERT_EMAIL_FROM= your_alert_email_from
ALERT_EMAIL_TO= your_alert_email_to
SMTP_HOST= your_smtp_host
SMTP_PORT= your_smtp_port
SMTP_USER= your_smtp_user
SMTP_PASS= your_smtp_pass
SMTP_USE_TLS= true
# Agentic Research (US-4.4) — required if Tavily is primary, fallback, or additional
# Brave Search API (web search + answers for enrichment)
TAVILY_API_KEY= your_tavily_api_key
BRAVE_SEARCH_API_KEY= your_brave_search_api_key
BRAVE_ANSWER_API_KEY= your_brave_answer_api_key
# SEC EDGAR User-Agent email (optional, recommended for higher rate limits)
SEC_EDGAR_EMAIL= your_email@example.com
# Nemotron investigation (optional)
OPENROUTER_API_KEY= your_openrouter_api_key
NVIDIA_API_KEY= your_nvidia_api_key
# Neo4j (Track B decision graph — internal Docker only)
NEO4J_AUTH=neo4j/change-me-in-production
NEO4J_PASSWORD=change-me-in-production
# For VPS deployment, uncomment and set your VPS IP in settings.yaml

# Dashboard operator authentication (session-based)
# Generate a password hash with:
# python - <<'PY'
# from dashboard.backend.app.services.auth import hash_password
# print(hash_password("choose-a-strong-password"))
# PY
# Generate a session secret with:
# python -c "import secrets; print(secrets.token_hex(32))"
# Set DASHBOARD_INSECURE_DEV_MODE=true only for localhost-only development.
# Operator login is blocked over plain HTTP in production.
# Slack Trade Commands (US-1.6) — Socket Mode for inbound trade commands
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...

# Deprecated bootstrap secret — no longer used by the frontend bundle.
DASHBOARD_API_KEY=
DASHBOARD_OPERATOR_USERNAME=operator
DASHBOARD_OPERATOR_PASSWORD_HASH=
DASHBOARD_SESSION_SECRET=
DASHBOARD_INSECURE_DEV_MODE=false
