# Dashboard frontend environment variables
# Copy to .env.local and fill in values for local development.

# Backend API base URL (leave empty for same-origin in production Docker build)
VITE_API_URL=http://localhost:8000

# Dashboard API key (US-7.1) — must match DASHBOARD_API_KEY set on the backend.
# Injected at build time; baked into the frontend bundle.
# For local dev without a build, set via browser console:
#   localStorage.setItem('dashboard_api_key', 'your-key')
VITE_API_KEY=
